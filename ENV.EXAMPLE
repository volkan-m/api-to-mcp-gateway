# PostgreSQL bağlantısı (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/mcp_gateway?schema=public"

# Credential şifreleme anahtarı.
# ÖNEMLİ: C# EncryptionService ile birebir uyum için bu değer, eski sistemde
# kullanılan ENCRYPTION_KEY ile AYNI olmalıdır. Anahtar 32 karaktere padlenir/kırpılır.
ENCRYPTION_KEY="default_encryption_key_32_chars_!!"

# MCP HTTP transport için opsiyonel statik bearer token (credential yoksa fallback)
BEARER_TOKEN=""

# Yönetim API'si / UI / MCP transport için kimlik doğrulama.
# AUTH_TOKEN ayarlanmazsa kimlik doğrulama DEVRE DIŞIDIR (sadece geliştirme için).
# Production'da MUTLAKA ayarlayın. AUTH_TOKEN aynı zamanda X-API-Key/Bearer
# değeri olarak da kullanılır (n8n, MCP istemcileri).
AUTH_TOKEN=""
# Yönetim paneline giriş şifresi (AUTH_TOKEN ile birlikte ayarlanmalı).
ADMIN_PASSWORD=""

# stdio MCP modu için hedef entegrasyon (mcp/stdio.ts)
INTEGRATION_ID=""

# Proxy çağrılarında TLS sertifika doğrulaması varsayılan olarak AÇIKTIR (güvenli).
# Self-signed sertifikalı dahili API'ler için "true" yaparak devre dışı bırakabilirsiniz.
# Production'da mümkünse "false" (veya boş) bırakın.
MCP_PROXY_INSECURE_TLS="false"

# MCP HTTP transport tool önbelleği TTL'i (ms). Bu süre dolduğunda tool/endpoint
# tanımları DB'den yeniden yüklenir. Varsayılan: 5000.
MCP_TOOL_CACHE_TTL_MS="5000"
